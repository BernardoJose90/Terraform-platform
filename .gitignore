# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories — provider binaries, module caches, and
# cached remote state. These are regenerated by `terraform init` and should
# never be committed (they're often huge and OS/arch-specific).
**/.terraform/*

# Keep the lock file so provider versions stay pinned/reproducible for
# everyone running `terraform init` — this one SHOULD be committed.
!**/.terraform.lock.hcl

# Terraform state files — these contain secrets/resource attributes in
# plaintext and must never be in git, even if you're using an S3 backend
# for the "real" state (local .tfstate can still get created accidentally,
# e.g. by `-backend=false` during `terraform validate`).
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Plan output files — these can contain sensitive values (secrets,
# resource IDs) and are meant to be short-lived CI artifacts, not
# committed to the repo.
*.tfplan
*.tfplan.*
tfplan.binary
plan_output.txt
apply_output.txt

# Variable files that typically hold secrets/environment-specific values.
# If you keep example/template files, name them *.tfvars.example and they
# will NOT be ignored by the pattern below.
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.json.example

# Override files — used for local overrides, should stay local
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration (can contain credentials)
.terraformrc
terraform.rc

# =============================================================================
# AWS
# =============================================================================
.aws/
*.pem
credentials
aws-exports.js

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Logs / temp
# =============================================================================
*.log
tmp/
temp/